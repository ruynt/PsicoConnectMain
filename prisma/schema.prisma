generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  passwordHash  String
  role          Role
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  emailVerified DateTime?
  patient       Patient?
  psychologist  Psychologist?
}

model Psychologist {
  id           String        @id @default(uuid())
  userId       String        @unique
  crp          String        @unique
  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]
  notes        SessionNote[]

  patientLinks PsychologistPatient[]
}

model Patient {
  id           String        @id @default(uuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]
  notes        SessionNote[]

  psychologistLinks PsychologistPatient[]
}

model PsychologistPatient {
  id             String       @id @default(uuid())

  psychologistId String
  psychologist   Psychologist @relation(fields: [psychologistId], references: [id])

  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id])

  active         Boolean      @default(true)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([psychologistId, patientId])
  @@index([psychologistId])
  @@index([patientId])
}

model Appointment {
  id              String            @id @default(uuid())
  title           String?
  description     String?
  location        String?
  dateTime        DateTime
  endDateTime     DateTime?
  googleEventId   String?           @unique
  googleEventLink String?
  status          AppointmentStatus @default(SCHEDULED)

  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])

  psychologistId  String
  psychologist    Psychologist      @relation(fields: [psychologistId], references: [id])

  notes           SessionNote[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([dateTime])
  @@index([psychologistId, dateTime])
  @@index([patientId, dateTime])
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime

  @@unique([email, token])
}

model SessionNote {
  id             String       @id @default(uuid())

  title          String?
  content        String

  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id])

  psychologistId String
  psychologist   Psychologist @relation(fields: [psychologistId], references: [id])

  appointmentId  String?
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  archived       Boolean      @default(false)
archivedAt     DateTime?

  @@index([patientId, createdAt])
  @@index([psychologistId, createdAt])
  @@index([appointmentId])
}

enum Role {
  PSYCHOLOGIST
  PATIENT
}

enum AppointmentStatus {
  SCHEDULED
  CANCELLED
}