generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          Role
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified DateTime?

  acceptedTermsAt              DateTime?
  acceptedTermsVersion         String?
  acceptedPrivacyAt            DateTime?
  acceptedPrivacyVersion       String?
  acceptedAiPolicyAt           DateTime?
  acceptedAiPolicyVersion      String?
  acceptedSensitiveDataAt      DateTime?
  acceptedSensitiveDataVersion String?

  profileImageUrl String?
  phone           String?
  city            String?
  state           String?
  bio             String?

  patient      Patient?
  psychologist Psychologist?
}

model Psychologist {
  id     String @id @default(uuid())
  userId String @unique
  crp    String @unique

  crpRegion String?
  crpState  String?
  crpNumber String?

  crpVerificationStatus CrpVerificationStatus @default(PENDING)
  crpVerifiedAt         DateTime?

  crpRejectedAt      DateTime?
  crpRejectionReason String?

  professionalTitle String?
  approach          String?
  specialties       String?
  education         String?
  targetAudience    String?
  instagramUrl      String?

  googleAccessToken        String?
  googleRefreshToken       String?
  googleAccessTokenExpires DateTime?
  googleCalendarEmail      String?

  user User @relation(fields: [userId], references: [id])

  appointments Appointment[]
  notes        SessionNote[]
  materials    PatientMaterial[]

  patientLinks PsychologistPatient[]

  therapeuticTasks TherapeuticTask[]
  patientMessages  PatientMessage[]
  patientSummaries PatientSummary[]

  @@index([crpVerificationStatus])
}

model Patient {
  id     String @id @default(uuid())
  userId String @unique

  socialName            String?
  birthDate             DateTime?
  contactPreference     String?
  emergencyContactName  String?
  emergencyContactPhone String?
  patientNotes          String?

  user User @relation(fields: [userId], references: [id])

  appointments Appointment[]
  notes        SessionNote[]
  materials    PatientMaterial[]

  psychologistLinks  PsychologistPatient[]
  preSessionCheckins PreSessionCheckin[]

  therapeuticTasks TherapeuticTask[]
  patientMessages   PatientMessage[]
  summaries         PatientSummary[]
}

model PsychologistPatient {
  id String @id @default(uuid())

  psychologistId String
  psychologist   Psychologist @relation(fields: [psychologistId], references: [id])

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  active Boolean @default(true)
  status PsychologistPatientStatus @default(APPROVED)

  requestedAt DateTime  @default(now())
  respondedAt DateTime?
  rejectedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([psychologistId, patientId])
  @@index([psychologistId])
  @@index([patientId])
  @@index([status])
  @@index([patientId, status])
  @@index([psychologistId, status])
}

model Appointment {
  id              String            @id @default(uuid())
  title           String?
  description     String?
  location        String?
  dateTime        DateTime
  endDateTime     DateTime?
  googleEventId   String?           @unique
  googleEventLink String?
  status          AppointmentStatus @default(SCHEDULED)

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  psychologistId String
  psychologist   Psychologist @relation(fields: [psychologistId], references: [id])

  notes              SessionNote[]
  preSessionCheckins PreSessionCheckin[]
  therapeuticTasks   TherapeuticTask[]

  cancellationReason String?
  cancelledAt        DateTime?

  confirmationStatus AppointmentConfirmationStatus @default(PENDING)
  confirmedAt        DateTime?

  cancellationRequestedAt   DateTime?
  cancellationRequestReason String?
  cancellationRequestStatus CancellationRequestStatus?

  lastReminderSentAt  DateTime?
  reminderEmailSentAt DateTime?

  paymentStatus PaymentStatus @default(PENDING)
  paymentAmount Decimal?      @db.Decimal(10, 2)
  paymentNote   String?
  paidAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dateTime])
  @@index([psychologistId, dateTime])
  @@index([patientId, dateTime])
  @@index([confirmationStatus])
  @@index([cancellationRequestStatus])
  @@index([paymentStatus])
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime

  @@unique([email, token])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model SessionNote {
  id String @id @default(uuid())

  title   String?
  content String

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  psychologistId String
  psychologist   Psychologist @relation(fields: [psychologistId], references: [id])

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  archived   Boolean   @default(false)
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, createdAt])
  @@index([psychologistId, createdAt])
  @@index([appointmentId])
}

model PreSessionCheckin {
  id String @id @default(uuid())

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  moodLevel    Int?
  anxietyLevel Int?
  sleepLevel   Int?

  mainConcern     String?
  importantEvents String?
  topicsToDiscuss String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([appointmentId, patientId])
  @@index([appointmentId])
  @@index([patientId])
}

model TherapeuticTask {
  id String @id @default(uuid())

  title       String
  description String?
  dueDate     DateTime?
  status      TherapeuticTaskStatus @default(PENDING)

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  psychologistId String
  psychologist   Psychologist @relation(fields: [psychologistId], references: [id])

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  completedAt DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([psychologistId])
  @@index([appointmentId])
  @@index([status])
}

model PatientMaterial {
  id String @id @default(uuid())

  title       String
  description String?
  category    String?
  url         String?
  content     String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  psychologistId String
  psychologist   Psychologist @relation(fields: [psychologistId], references: [id])

  viewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([psychologistId])
  @@index([createdAt])
}

model PatientMessage {
  id String @id @default(uuid())

  content String

  senderRole MessageSenderRole

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  psychologistId String
  psychologist   Psychologist @relation(fields: [psychologistId], references: [id])

  readByPatientAt      DateTime?
  readByPsychologistAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, createdAt])
  @@index([psychologistId, createdAt])
  @@index([senderRole])
}

model PatientSummary {
  id String @id @default(uuid())

  title   String?
  content String

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  psychologistId String
  psychologist   Psychologist @relation(fields: [psychologistId], references: [id])

  sourceNotesCount Int?
  generatedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, createdAt])
  @@index([psychologistId, createdAt])
}

model AuditLog {
  id String @id @default(uuid())

  actorUserId String?
  actorRole   Role?

  action     String
  entityType String
  entityId   String?

  targetUserId String?

  ipAddress String?
  userAgent String?
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}

enum Role {
  ADMIN
  PSYCHOLOGIST
  PATIENT
}

enum PsychologistPatientStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AppointmentStatus {
  SCHEDULED
  CANCELLED
}

enum AppointmentConfirmationStatus {
  PENDING
  CONFIRMED
  CANCELLATION_REQUESTED
}

enum CancellationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  EXEMPT
}

enum TherapeuticTaskStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum MessageSenderRole {
  PSYCHOLOGIST
  PATIENT
}

enum CrpVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}